# ============================================================
# WARNING: This file has NO EFFECT on Vercel (serverless).
# Route guards are enforced in vercel.json instead.
# This file only applies to local Apache/XAMPP development.
# ============================================================

# Deny direct directory listing
Options -Indexes

# Block access to sensitive files
<FilesMatch "\.(sql|log|env|json|md)$">
    Order deny,allow
    Deny from all
</FilesMatch>

# Block access to config and includes from browser
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block specific directories
    RewriteRule ^config/ - [F,L]
    RewriteRule ^includes/ - [F,L]
    RewriteRule ^database/ - [F,L]

    # Enable extensionless PHP URLs (e.g. /pages/browse -> /pages/browse.php)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}\.php -f
    RewriteRule ^(.*)$ $1.php [L]
</IfModule>
